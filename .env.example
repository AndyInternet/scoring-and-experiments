# Local dev needs NO keys — the `pnpm dev` script sets INNGEST_DEV=1, which points
# the SDK at the dev server (http://localhost:8288). Set INNGEST_DEV=1 yourself only
# if you run `next` without that script.
#
# Set these only for Inngest Cloud (e.g. on Vercel):
# INNGEST_SIGNING_KEY=signkey-prod-...
# INNGEST_EVENT_KEY=...

# Optional: override the dashboard base URL used for "view run" links.
# DASHBOARD_URL=http://localhost:8288

# Optional: the Inngest Cloud environment slug used in dashboard run links
# (https://app.inngest.com/env/<INNGEST_ENV>/functions/...). Defaults to "production".
# INNGEST_ENV=production

# Password gate. When set, every route except /api/inngest (and the login page)
# requires this password. Leave unset to disable the gate (e.g. local dev).
# APP_PASSWORD=change-me
